# Port for the Node server
PORT=3000

# Official AD login endpoint to redirect users to
AD_LOGIN_URL=https://uatintegrationsistio.ncbagroup.com/ad-login/authentication

# Test credentials used by /api/test-login
TEST_USERNAME=user@example.com
TEST_PASSWORD=string

# If your internal TLS cert isn't trusted by Node in the deployment environment,
# you can temporarily bypass verification (NOT recommended for production).
ALLOW_INSECURE_TLS=false
